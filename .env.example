# ============================================
# TELEGRAM CONFIGURATION (REQUIRED)
# ============================================
# Get from @BotFather: https://t.me/BotFather
TELEGRAM_TOKEN=

# Your Telegram user ID (optional, for admin features)
OWNER_ID=733340342

# Webhook URL (optional, for deployment)
WEBHOOK_URL=

# ============================================
# AI SERVICES (Add at least ONE)
# ============================================

# --- GROQ (FREE & FAST - Recommended) ---
# Get from: https://console.groq.com
GROQ_API_KEY=
GROQ_API_KEY1=
GROQ_API_KEY2=
GROQ_API_KEY3=

# --- GEMINI (FREE - Google AI) ---
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_API_KEY1=

# --- OPENROUTER (FREE Tier Available) ---
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_API_KEY2=

# --- OPENAI (PAID - Optional Fallback) ---
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ============================================
# VOICE SERVICES (Optional)
# ============================================

# Sarvam AI - Indian Voices (FREE)
# Get from: https://www.sarvam.ai
SARVAM_API_KEY=

# Note: Edge TTS and Google TTS are built-in (no key needed)

# ============================================
# OTHER APIS (Optional Features)
# ============================================
NEWS_API_KEY=
SERPAPI_KEY=
OPENWEATHER_API_KEY=
CITY=Mumbai
